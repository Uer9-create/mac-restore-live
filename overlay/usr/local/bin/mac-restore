#!/usr/bin/env bash
# mac-restore — wrapper around idevicerestore with safety checks
set -euo pipefail

RED='\033[0;31m'; GREEN='\033[0;32m'; YELLOW='\033[1;33m'; CYAN='\033[0;36m'; NC='\033[0m'

header() {
  echo -e "${CYAN}"
  echo "╔══════════════════════════════════════════════╗"
  echo "║          Mac Restore Live — idevicerestore   ║"
  echo "╚══════════════════════════════════════════════╝"
  echo -e "${NC}"
}

usage() {
  echo "Usage: sudo mac-restore [IPSW_FILE]"
  echo ""
  echo "  If no IPSW file is given, the script will look in ~/Downloads"
  echo "  and let you pick from available .ipsw files."
  echo ""
  echo "  Your Mac must be in DFU or Recovery mode before running."
  echo "  Connect via USB-C directly — hubs may cause issues."
}

check_root() {
  [ "$EUID" -eq 0 ] || { echo -e "${RED}Please run as root: sudo mac-restore${NC}"; exit 1; }
}

find_ipsw() {
  SEARCH_DIRS=("$HOME/Downloads" "/tmp" "/media")
  FILES=()
  for d in "${SEARCH_DIRS[@]}"; do
    while IFS= read -r -d '' f; do
      FILES+=("$f")
    done < <(find "$d" -maxdepth 3 -name "*.ipsw" -print0 2>/dev/null)
  done

  if [ ${#FILES[@]} -eq 0 ]; then
    echo -e "${YELLOW}No .ipsw files found. Run 'ipsw-downloader' first.${NC}"
    exit 1
  fi

  echo -e "${CYAN}Available IPSW files:${NC}"
  for i in "${!FILES[@]}"; do
    SIZE=$(du -sh "${FILES[$i]}" 2>/dev/null | cut -f1)
    echo "  [$((i+1))] ${FILES[$i]} ($SIZE)"
  done

  while true; do
    read -rp "Select file (1-${#FILES[@]}): " SEL
    if [[ "$SEL" =~ ^[0-9]+$ ]] && [ "$SEL" -ge 1 ] && [ "$SEL" -le "${#FILES[@]}" ]; then
      echo "${FILES[$((SEL-1))]}"
      return
    fi
    echo "Invalid selection."
  done
}

check_device() {
  echo -e "${CYAN}Checking for device in DFU/Recovery mode...${NC}"
  if ! lsusb 2>/dev/null | grep -qiE "apple|05ac"; then
    echo -e "${YELLOW}Warning: No Apple USB device detected.${NC}"
    echo "Make sure your Mac is:"
    echo "  1. Connected via USB-C"
    echo "  2. In DFU mode (hold Power+Vol Down on Apple Silicon)"
    echo "     or Recovery mode (hold Power until Options appears, then Terminal → reinstall)"
    read -rp "Continue anyway? [y/N]: " CONT
    [[ "$CONT" =~ ^[Yy]$ ]] || exit 1
  else
    echo -e "${GREEN}Apple device detected via USB.${NC}"
  fi
}

main() {
  header
  check_root

  if [ "${1:-}" = "--help" ] || [ "${1:-}" = "-h" ]; then
    usage; exit 0
  fi

  IPSW="${1:-}"
  if [ -z "$IPSW" ]; then
    IPSW=$(find_ipsw)
  fi

  [ -f "$IPSW" ] || { echo -e "${RED}File not found: $IPSW${NC}"; exit 1; }

  check_device

  echo ""
  echo -e "${YELLOW}About to restore using:${NC}"
  echo "  IPSW: $IPSW"
  echo "  Size: $(du -sh "$IPSW" | cut -f1)"
  echo ""
  echo -e "${RED}WARNING: This will ERASE all data on the target Mac.${NC}"
  read -rp "Type YES to confirm and begin restore: " CONFIRM
  [ "$CONFIRM" = "YES" ] || { echo "Aborted."; exit 1; }

  echo ""
  echo -e "${GREEN}Starting idevicerestore...${NC}"
  idevicerestore -e "$IPSW"
}

main "$@"
